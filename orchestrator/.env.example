# Master Slack App tokens
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# App Configuration Token (for Manifest API)
# Get this from https://api.slack.com/reference/manifests#config-tokens
SLACK_APP_CONFIGURATION_TOKEN=xoxe-your-config-token

# SQLite database path
DATABASE_PATH=./data/harry-botter.db

# Kubernetes namespace for NanoClaw pods
K8S_NAMESPACE=nanoclaw
