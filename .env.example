# === Slack Master App ===
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_APP_CONFIGURATION_TOKEN=xoxe-your-config-token

# === Event Gateway ===
# Public HTTPS URL where Slack sends events (use ngrok for local dev)
EVENT_GATEWAY_URL=https://your-ngrok-url.ngrok-free.app
EVENT_GATEWAY_PORT=3001

# === Kubernetes ===
K8S_NAMESPACE=harrybotter

# === Optional ===
# ORG_ANTHROPIC_KEY=sk-ant-org-shared-key
# ADMIN_USER_IDS=U12345,U67890
# ADMIN_CHANNEL_ID=C12345
# DEFAULT_RETENTION_MODE=retain
# MAX_BACKUP_SIZE_MB=1024
